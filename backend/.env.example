APP_NAME=TimeTracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8020
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://na9.replicon.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=timetracker
DB_USERNAME=tt
DB_PASSWORD=tt

# Postgres (used by the 'postgres' service - keep in sync with the above)
POSTGRES_DB=timetracker
POSTGRES_USER=tt
POSTGRES_PASSWORD=tt

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=supabase
QUEUE_CONNECTION=database

# Supabase Storage (S3-compatible) — required for logo uploads
SUPABASE_S3_KEY=
SUPABASE_S3_SECRET=
SUPABASE_S3_REGION=ca-central-1
SUPABASE_S3_BUCKET=timetracker
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="Time Tracker"

SANCTUM_TOKEN_PREFIX=tt_
BROWSERSHOT_CHROMIUM_PATH=/usr/bin/chromium-browser

