# Docker Compose — local dev environment
# Copy to .env and fill in values.

# Postgres (used by the 'postgres' service and referenced by laravel/queue)
POSTGRES_DB=timetracker
POSTGRES_USER=tt
POSTGRES_PASSWORD=tt

# Laravel / Queue
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8020
FRONTEND_URL=http://localhost:3000
DB_HOST=postgres
DB_DATABASE=timetracker
DB_USERNAME=tt
DB_PASSWORD=tt
MAIL_HOST=mailpit
MAIL_PORT=1025

# Frontend (Nuxt)
NUXT_PUBLIC_API_BASE=http://localhost:8020
NUXT_PUBLIC_APP_NAME=Time Tracker
